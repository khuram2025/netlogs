# =============================================================================
# NetLogs SOAR/SIEM Platform - Environment Configuration
# Copy this file to .env and update values for your deployment
# =============================================================================

# --- Application -----------------------------------------------------------
DEBUG=false
# SECRET_KEY is auto-generated if not set. Set explicitly for multi-instance
# deployments or to persist sessions across restarts.
# SECRET_KEY=your-secret-key-here
ALLOWED_HOSTS=*
TZ=Asia/Riyadh

# --- PostgreSQL ------------------------------------------------------------
POSTGRES_HOST=postgres          # Docker service name (use localhost for bare metal)
POSTGRES_PORT=5432
POSTGRES_DB=netlogs
POSTGRES_USER=netlogs           # CHANGE IN PRODUCTION
POSTGRES_PASSWORD=ChangeMeNow!  # CHANGE IN PRODUCTION

# --- ClickHouse ------------------------------------------------------------
CLICKHOUSE_HOST=clickhouse      # Docker service name (use localhost for bare metal)
CLICKHOUSE_PORT=8123
CLICKHOUSE_DB=default
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=ChangeMeNow!  # CHANGE IN PRODUCTION

# --- Web Server ------------------------------------------------------------
WORKERS=4                       # Uvicorn worker count (recommended: 2 * CPU cores)

# --- Syslog Collector ------------------------------------------------------
SYSLOG_PORT=514
SYSLOG_BATCH_SIZE=5000          # Logs per batch insert
SYSLOG_FLUSH_INTERVAL=2.0       # Seconds between flushes
SYSLOG_CACHE_TTL=60             # Device cache TTL in seconds
SYSLOG_WORKERS=4                # DB writer threads
SYSLOG_MAX_BUFFER=100000        # Max buffered logs before dropping
SYSLOG_METRICS_INTERVAL=30      # Stats logging interval in seconds

# --- Logging ---------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FILE=logs/netlogs.log
