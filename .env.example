# =============================================================================
# Zentryc SOAR/SIEM Platform - Environment Configuration
# Copy this file to .env and update values for your deployment
# =============================================================================

# --- Application -----------------------------------------------------------
DEBUG=false
# SECRET_KEY is auto-generated if not set. Set explicitly for multi-instance
# deployments or to persist sessions across restarts.
# SECRET_KEY=your-secret-key-here
ALLOWED_HOSTS=*
TZ=Asia/Riyadh

# --- PostgreSQL ------------------------------------------------------------
# Docker service name (use localhost for bare metal)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=zentryc
POSTGRES_USER=zentryc
POSTGRES_PASSWORD=ChangeMeNow!

# --- ClickHouse ------------------------------------------------------------
# Docker service name (use localhost for bare metal)
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_DB=default
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=ChangeMeNow!

# --- Web Server ------------------------------------------------------------
# Uvicorn worker count (recommended: 2 * CPU cores)
WORKERS=4

# --- Syslog Collector ------------------------------------------------------
SYSLOG_PORT=514
SYSLOG_BATCH_SIZE=5000          # Logs per batch insert
SYSLOG_FLUSH_INTERVAL=2.0       # Seconds between flushes
SYSLOG_CACHE_TTL=60             # Device cache TTL in seconds
SYSLOG_WORKERS=4                # DB writer threads
SYSLOG_MAX_BUFFER=100000        # Max buffered logs before dropping
SYSLOG_METRICS_INTERVAL=30      # Stats logging interval in seconds

# --- Redis -----------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# --- Networking ------------------------------------------------------------
# Docker bridge subnets — CHANGE if they conflict with your internal network.
# Must not overlap with any real network the host can reach.
DOCKER_SUBNET_FRONTEND=10.200.0.0/24
DOCKER_SUBNET_BACKEND=10.200.1.0/24

# --- Logging ---------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FILE=logs/netlogs.log
